{
  "name": "pjangler",
  "version": "1.0.0",
  "description": "Project subsystem bootstrapper CLI",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "pjangler": "src/index.ts",
    "pj": "src/index.ts",
    "pjangler-mcp": "src/mcp-server.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "mcp": "bun run src/mcp-server.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:mcp": "bun build ./src/mcp-server.ts --outdir ./dist --target node"
  },
  "keywords": ["cli", "bootstrap", "project-setup", "mise", "docker"],
  "author": "delorenj",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "zod": "^4.4.3"
  }
}
