{
  "name": "@delorenj/pjangler",
  "version": "1.2.15",
  "description": "Project subsystem bootstrapper CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pjangler": "dist/index.js",
    "pj": "dist/index.js",
    "pjangler-mcp": "dist/mcp-server.js"
  },
  "files": [
    "dist",
    "templates",
    ".mise/scripts/versioning.sh",
    ".mise/scripts/link-agentfiles.sh"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "esbuild src/index.ts src/mcp-server.ts --bundle --packages=external --platform=node --format=esm --outdir=dist",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp-server.js",
    "typecheck": "tsc --noEmit",
    "test": "node tests/parity-migrate-regressions.mjs && node tests/mcp-catalog-regressions.mjs && node tests/mcp-server-regressions.mjs && node tests/project-registry-regressions.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "bootstrap",
    "project-setup",
    "mise",
    "docker"
  ],
  "author": "delorenj",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.25.0",
    "typescript": "^5"
  }
}
